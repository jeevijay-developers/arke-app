<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </base-config>

    <!--
        megas4.com S3 endpoint uses a certificate that may not be in the
        Android system store. Trust user-installed CAs for this domain so
        the WebView and platform HTTP clients can reach it.
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">megas4.com</domain>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </domain-config>
</network-security-config>
